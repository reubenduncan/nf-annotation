// ============================================================
// Nextflow configuration — annotation pipeline
// ============================================================

process {
    cpus   = 4
    memory = '8 GB'

    withLabel: 'high_cpu' {
        cpus   = 16
        memory = '128 GB'   // GTDB-Tk is memory-hungry
    }

    withLabel: 'medium_cpu' {
        cpus   = 8
        memory = '32 GB'
    }

    // DECOMPRESS uses gunzip from alpine — no heavy resources needed
    withName: 'DECOMPRESS' {
        cpus   = 1
        memory = '1 GB'
    }
}

// ============================================================
// Execution profiles
// Select with: nextflow run main.nf -profile <name>
//   (no profile)           Conda / Mamba (default)
//   -profile docker        Docker containers
//   -profile singularity   Singularity (HPC without Docker)
//   -profile slurm         SLURM cluster (combine: -profile slurm,docker or slurm,singularity)
// ============================================================

// Default runtime: conda (mamba used automatically when available)
conda.enabled  = true
conda.useMamba = true

profiles {

    // Docker — explicit opt-in
    docker {
        conda.enabled     = false
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    // Singularity (for HPC clusters that don't allow Docker)
    singularity {
        conda.enabled          = false
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    // Conda / Mamba — explicit opt-in (same as default, useful when combining profiles)
    conda {
        conda.enabled   = true
        conda.useMamba  = true   // falls back to conda if mamba is not installed
    }

    // SLURM cluster — tweak queue/account as needed.
    // Combine with another profile for software management:
    //   -profile slurm,conda  or  -profile slurm,singularity
    slurm {
        process.executor = 'slurm'
        process.queue    = 'main'

        process {
            withLabel: 'high_cpu' {
                cpus   = 16
                memory = '128 GB'
                time   = '48h'
            }
            withLabel: 'medium_cpu' {
                cpus   = 8
                memory = '32 GB'
                time   = '24h'
            }
            withName: 'TAXONOMY' {
                // GTDB-Tk may need a scratch directory on HPC
                clusterOptions = '--tmp=200GB'
            }
        }
    }
}

// Resume crashed runs automatically
resume = true

// Trace / report outputs
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}
