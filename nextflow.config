// ============================================================
// Nextflow configuration — annotation pipeline
// ============================================================

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    // Default resources
    cpus   = 4
    memory = '8 GB'

    withLabel: 'high_cpu' {
        cpus   = 16
        memory = '128 GB'   // GTDB-Tk is memory-hungry
    }

    withLabel: 'medium_cpu' {
        cpus   = 8
        memory = '32 GB'
    }

    // DECOMPRESS uses gunzip from alpine — no heavy resources needed
    withName: 'DECOMPRESS' {
        cpus   = 1
        memory = '1 GB'
    }
}

// Execution profiles
profiles {

    // Default: Docker on a single machine
    standard {
        docker.enabled = true
    }

    // Singularity (for HPC clusters that don't allow Docker)
    singularity {
        docker.enabled      = false
        singularity.enabled = true
        singularity.autoMounts = true
    }

    // SLURM cluster — tweak queue/account as needed
    slurm {
        process.executor = 'slurm'
        process.queue    = 'main'

        process {
            withLabel: 'high_cpu' {
                cpus   = 16
                memory = '128 GB'
                time   = '48h'
            }
            withLabel: 'medium_cpu' {
                cpus   = 8
                memory = '32 GB'
                time   = '24h'
            }
            withName: 'TAXONOMY' {
                // GTDB-Tk may need a scratch directory on HPC
                clusterOptions = '--tmp=200GB'
            }
        }
    }
}

// Resume crashed runs automatically
resume = true

// Trace / report outputs
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
    overwrite = true
}
